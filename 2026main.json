  "sections": [
    {
      "name": "Prematch",
      "fields": [
        {
          "title": "Scouter Initials",
          "description": "Enter your first and last initial here. Maintain the same format every time you scout (e.g., two letters, both capitalized, no spaces).",
          "type": "text",
          "required": true,
          "code": "scouter",
          "formResetBehavior": "preserve",
          "defaultValue": ""
        },
        {
          "title": "Team Number",
          "description": "The team number of the robot you're scouting.",
          "type": "number",
          "required": true,
          "code": "teamNumber",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "min": 0,
          "max": 99999
        },
        {
          "title": "Match Number",
          "description": "Enter the match number.",
          "type": "number",
          "required": true,
          "code": "matchNumber",
          "formResetBehavior": "increment",
          "defaultValue": 1
        },
        {
          "title": "Starting Position",
          "description": "The starting position of the robot.",
          "type": "select",
          "required": true,
          "code": "startingPosition",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "choices": {
            "Outpost": "Outpost Side",
            "Middle": "Middle",
            "Depot": "Depot Side"
          }
        },
        {
          "title": "No Show",
          "description": "Select if the robot did not come to the match.",
          "type": "boolean",
          "required": false,
          "code": "noShow",
          "formResetBehavior": "reset",
          "defaultValue": false
        }
      ]
    },
    {
      "name": "Autonomous",
      "fields": [
        {
          "title": "Shooting Time",
          "description": "Time spent actively projecting (not necessarily scoring, just shooting) fuel",
          "type": "timer",
          "required": false,
          "code": "autoShootTime",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "outputType": "list"
        },
        {
          "title": "Moved?",
          "description": "Select if the robot moved at all.",
          "type": "boolean",
          "required": false,
          "code": "noShow",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Intake in neutral?",
          "description": "Select if the robot picked up fuel in the center.",
          "type": "boolean",
          "required": false,
          "code": "enteredNeutral",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Climbed Tower",
          "description": "The height the robot climbed in auto.",
          "type": "select",
          "required": false,
          "code": "climbedAuto",
          "formResetBehavior": "reset",
          "defaultValue": "No",
          "choices": {
            "No": "Didn't Climb",
            "L1": "Level 1",
            "F": "Failed Climb"
          }
        }
      ]
    },
    {
      "name": "Teleop",
      "fields": [
        {
          "title": "Shooting Time",
          "description": "Time spent actively projecting fuel, either in passing or scoring",
          "type": "timer",
          "required": false,
          "code": "shootTimeActive",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "outputType": "list"
        },
        {
          "title": "Teleop Climb",
          "type": "select",
          "required": false,
          "code": "climbedEndgame",
          "formResetBehavior": "reset",
          "defaultValue": "No",
          "choices": {
            "No": "Didn't Climb",
            "L1": "Level 1",
            "L2": "Level 2",
            "L3": "Level 3",
            "F": "Failed Climb"
          }
        }
      ]
    },
    {
      "name": "Postmatch",
      "fields": [
        {
          "title": "Estimated Firing Rate",
          "description": "Estimate the rate at which the robot shoots fuel.",
          "type": "range",
          "required": false,
          "code": "firingRate",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "min": 1,
          "max": 5,
          "step": 1
        },
        {
          "title": "Passing vs Scoring",
          "description": "Passing = 1, Shooting = 5; if they never shot, keep at default value.",
          "type": "range",
          "required": true,
          "code": "scorePassRole",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "min": 1,
          "max": 5,
          "step": 1
        },
        {
          "title": "Accuracy",
          "type": "select",
          "required": true,
          "code": "Accuracy",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "choices": {
            "1": "Made zero/very few",
            "2": "Missed most",
            "3": "Made half",
            "4": "Made most shots",
            "5": "Made all/missed very few"
          }
        },
        {
          "title": "Played Defense?",
          "description": "Did they play defense? Note: it does not count if an opposing robot was near them and they pinned them for two seconds. They have to be actively playing a defensive ROLE, where they are prioritzing defense.",
          "type": "boolean",
          "required": false,
          "code": "playedDefense",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Red Cards",
          "type": "counter",
          "required": false,
          "code": "autoFoul",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "min": 0,
          "step": 1
        },
        {
          "title": "Died?",
          "description": "Did they die in the match? If they were dead for less than five seconds or whatever, don't select. If they died for an extended period of time (even if they were not down for the remainder of the match), then select.",
          "type": "boolean",
          "required": false,
          "code": "died",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Fell Over?",
          "description": "Select if the robot tipped or fell over, even if a teammate was able to help them back up.",
          "type": "boolean",
          "required": false,
          "code": "helpIFell",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Comments",
          "description": "A good comment discusses strategy, points of failure, or critical circumstances. Pay attention to how the team's gameplay could have differed; comment on what made this match different. Comments should tell us what the quantitative data can't.",
          "type": "text",
          "required": false,
          "code": "comments",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "min": 0,
          "max": 200
        }
      ]
    }
  ]
}
